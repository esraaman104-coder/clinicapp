DATABASE_URL=postgresql://user:password@host:5432/dbname
# ──────────────────────────────────────────────────────
# JWT_SECRET: يجب أن يكون عشوائياً تماماً — لا كلمات بشرية أبداً
# لتوليد قيمة آمنة شغّل:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ──────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-use-command-above

# SUPABASE_JWT_SECRET: مطلوب في production — يُعرف من Supabase dashboard
SUPABASE_JWT_SECRET=
ENV=production

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
